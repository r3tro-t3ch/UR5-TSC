<mujoco model="ArmPi">

  <compiler angle="degree" autolimits="true"/>

  <option gravity="0 0 -9.81"/>

  <default>
    <joint damping="0.1"/>
    <geom type="box" rgba="0.7 0.7 0.7 1" contype="1" conaffinity="1"/>
  </default>

  <asset>
   <texture name="grid" type="2d" builtin="checker" width="512" height="512" rgb1=".1 .2 .3" rgb2=".2 .3 .4"/>
    <material name="grid" texture="grid" texrepeat="1 1" texuniform="true" reflectance=".2"/>
  </asset>

  <worldbody>

    <!-- Base (fixed to world) -->
    <geom name="floor" size="0 0 .05" type="plane" material="grid" condim="1" conaffinity="1"/>
    <light name="spotlight" mode="targetbodycom" target="wrist_3_link" pos="0 -1 2"/>
    <body name="base_link" pos="0 0 0.01">
      <geom name="base_geom" size="0.04 0.04 0.01" pos="0 0 0.01"/>
      <!-- base_motor: revolute around Z -->
      <joint name="base_motor" type="hinge" axis="0 0 1" pos="0 0 0"
             range="0 180" actuatorfrcrange="-10 10"/>

      <body name="link1" pos="0 0 0.02" euler="0 90 0">
        <geom name="link1_geom" size="0.015 0.015 0.05" pos="0 0 0.05"/>
        <!-- link1_motor: revolute around X -->
        <joint name="link1_motor" type="hinge" axis="0 -1 0" pos="0 0 0"
               range="0 180" actuatorfrcrange="-10 10"/>

        <body name="link2" pos="0 0 0.1">
          <geom name="link2_geom" size="0.015 0.0125 0.0475" pos="0 0 0.0475"/>
          <!-- link2_motor: revolute around X -->
          <joint name="link2_motor" type="hinge" axis="0 -1 0" pos="0 0 0"
                 range="-90 90" actuatorfrcrange="-10 10"/>

          <body name="link3" pos="0 0 0.095">
            <geom name="link3_geom" size="0.02 0.02 0.025" pos="0 0 0.025"/>
            <!-- link3_motor: revolute around X -->
            <joint name="link3_motor" type="hinge" axis="0 -1 0" pos="0 0 0"
                   range="-90 90" actuatorfrcrange="-10 10"/>

            <body name="wrist_3_link" pos="0 0 0.05">
              <geom name="link4_geom1" size="0.01 0.01 0.0025" pos="0 0 0.0025"/>
              <geom name="link4_geom2" size="0.03 0.025 0.015" pos="0 0 0.02"/>
              <!-- link4_motor: revolute around Z (wrist rotation) -->
              <joint name="link4_motor" type="hinge" axis="0 0 1" pos="0 0 0"
                     range="-180 180" actuatorfrcrange="-5 5"/>

              <!-- Left claw -->
              <body name="left_claw" pos="-0.015 0 0.035">
                <geom name="left_claw_geom" size="0.005 0.005 0.035" pos="-0.015 0 0.035"/>
              </body>

              <!-- Right claw -->
              <body name="right_claw" pos="0.015 0 0.035">
                <geom name="right_claw_geom" size="0.005 0.005 0.035" pos="0.015 0 0.035"/>
              </body>

              <site name="attachment_site" pos="0 0 0.035" quat="1 0 0 0"/>

            </body>
          </body>
        </body>
      </body>
    </body>

  </worldbody>

  <actuator>
    <motor name="base_motor_act"         joint="base_motor"         gear="1" ctrllimited="true" ctrlrange="-10 10"/>
    <motor name="link1_motor_act"        joint="link1_motor"        gear="1" ctrllimited="true" ctrlrange="-10 10"/>
    <motor name="link2_motor_act"        joint="link2_motor"        gear="1" ctrllimited="true" ctrlrange="-10 10"/>
    <motor name="link3_motor_act"        joint="link3_motor"        gear="1" ctrllimited="true" ctrlrange="-10 10"/>
    <motor name="link4_motor_act"        joint="link4_motor"        gear="1" ctrllimited="true" ctrlrange="-5 5"/>
  </actuator>


  <keyframe>
    <key name="home" qpos="-1.5708 -1.5708 1.5708 -1.5708 -1.5708" ctrl="-1.5708 -1.5708 1.5708 -1.5708 -1.5708"/>
  </keyframe>

</mujoco>