<mujoco model="ArmPi">

  <compiler angle="radian" autolimits="true"/>

  <option gravity="0 0 -9.81"/>

  <default>
    <joint damping="0.1"/>
    <geom type="box" rgba="0.7 0.7 0.7 1" contype="1" conaffinity="1"/>
  </default>

  <worldbody>

    <!-- Base (fixed to world) -->
    <body name="base_link" pos="0 0 0">
      <geom name="base_geom" size="0.04 0.04 0.01" pos="0 0 0.01"/>
      <!-- base_motor: revolute around Z -->
      <joint name="base_motor" type="hinge" axis="0 0 1" pos="0 0 0"
             range="-3.14159 3.14159" actuatorfrcrange="-10 10"/>

      <body name="link1" pos="0 0 0.02">
        <geom name="link1_geom" size="0.0275 0.015 0.05" pos="0 0 0.05"/>
        <!-- link1_motor: revolute around X -->
        <joint name="link1_motor" type="hinge" axis="1 0 0" pos="0 0 0"
               range="-1.5708 1.5708" actuatorfrcrange="-10 10"/>

        <body name="link2" pos="0 0 0.1">
          <geom name="link2_geom" size="0.015 0.0125 0.0475" pos="0 0 0.0475"/>
          <!-- link2_motor: revolute around X -->
          <joint name="link2_motor" type="hinge" axis="1 0 0" pos="0 0 0"
                 range="-2.0944 2.0944" actuatorfrcrange="-10 10"/>

          <body name="link3" pos="0 0 0.095">
            <geom name="link3_geom" size="0.02 0.02 0.025" pos="0 0 0.025"/>
            <!-- link3_motor: revolute around X -->
            <joint name="link3_motor" type="hinge" axis="1 0 0" pos="0 0 0"
                   range="-2.0944 2.0944" actuatorfrcrange="-10 10"/>

            <body name="link4" pos="0 0 0.05">
              <geom name="link4_geom1" size="0.01 0.01 0.0025" pos="0 0 0.0025"/>
              <geom name="link4_geom2" size="0.03 0.025 0.015" pos="0 0 0.02"/>
              <!-- link4_motor: revolute around Z (wrist rotation) -->
              <joint name="link4_motor" type="hinge" axis="0 0 1" pos="0 0 0"
                     range="-3.14159 3.14159" actuatorfrcrange="-5 5"/>

              <!-- Left claw -->
              <body name="left_claw" pos="-0.015 0 0.035">
                <geom name="left_claw_geom" size="0.015 0.0225 0.035" pos="-0.015 0 0.035"/>
                <joint name="gripper_left_motor" type="hinge" axis="0 -1 0" pos="0 0 0"
                       range="-0.216 0.216" actuatorfrcrange="-3 3"/>
              </body>

              <!-- Right claw -->
              <body name="right_claw" pos="0.015 0 0.035">
                <geom name="right_claw_geom" size="0.015 0.0225 0.035" pos="0.015 0 0.035"/>
                <joint name="gripper_right_motor" type="hinge" axis="0 1 0" pos="0 0 0"
                       range="-0.216 0.216" actuatorfrcrange="-3 3"/>
              </body>

            </body>
          </body>
        </body>
      </body>
    </body>

  </worldbody>

  <actuator>
    <motor name="base_motor_act"         joint="base_motor"         gear="1" ctrllimited="true" ctrlrange="-10 10"/>
    <motor name="link1_motor_act"        joint="link1_motor"        gear="1" ctrllimited="true" ctrlrange="-10 10"/>
    <motor name="link2_motor_act"        joint="link2_motor"        gear="1" ctrllimited="true" ctrlrange="-10 10"/>
    <motor name="link3_motor_act"        joint="link3_motor"        gear="1" ctrllimited="true" ctrlrange="-10 10"/>
    <motor name="link4_motor_act"        joint="link4_motor"        gear="1" ctrllimited="true" ctrlrange="-5 5"/>
    <motor name="gripper_left_motor_act" joint="gripper_left_motor" gear="1" ctrllimited="true" ctrlrange="-3 3"/>
    <motor name="gripper_right_motor_act"joint="gripper_right_motor"gear="1" ctrllimited="true" ctrlrange="-3 3"/>
  </actuator>

</mujoco>